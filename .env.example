# Supabase credentials
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_OR_ANON_KEY

# Preferred Supabase Postgres connection string
# Copy the DATABASE_URL value from the Supabase project settings.
DATABASE_URL=postgresql://your_db_user:your_db_password@YOUR_PROJECT_ID.db.supabase.co:5432/your_db_name?sslmode=require

# Alternative explicit settings (optional)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=YOUR_PROJECT_ID.db.supabase.co
# DB_PORT=5432

# If you only want local development with SQLite, remove or comment out DATABASE_URL and DB_ENGINE.
